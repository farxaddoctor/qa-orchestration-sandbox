              "pattern": "^results/SIM-004-"
            }
          }
        }
      ]
    },
    "artifact_sim_005": {
      "allOf": [
        {
          "$ref": "#/$defs/artifact_descriptor"
        },
        {
          "type": "object",
          "properties": {
            "evidence_id": {
              "type": "string",
              "pattern": "^SIM-005:"
            },
            "result_path": {
