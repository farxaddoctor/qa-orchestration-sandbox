{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:qa-orchestration-sandbox:evidence:v1:routing-trace",
  "title": "QA orchestration routing trace",
  "description": "Version 1 contract for the required Consumer simulation routing trace.",
  "type": "object",
  "required": [
    "schema_version",
    "simulation_id",
    "status",
    "command",
    "constitution",
    "policies",
    "workflow",
    "primary_agent",
    "supporting_agents",
    "skills",
    "audit_before_edit",
    "human_gate",
    "stop_condition",
    "expected_artifact"
  ],
  "properties": {
    "schema_version": {
      "const": "1.0.0"
    },
    "simulation_id": {
      "enum": [
        "SIM-001",
        "SIM-002",
        "SIM-003",
        "SIM-004",
        "SIM-005",
        "SIM-006"
      ]
    },
    "status": {
      "enum": [
        "PASS",
        "FAIL",
        "BLOCKED",
        "HUMAN_APPROVAL_REQUIRED"
      ]
    },
    "command": {
      "type": "string",
      "minLength": 1
    },
    "constitution": {
      "type": "string",
      "minLength": 1
    },
    "policies": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "workflow": {
      "type": "string",
      "minLength": 1
    },
    "primary_agent": {
      "type": "string",
      "minLength": 1
    },
    "supporting_agents": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "skills": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "audit_before_edit": {
      "type": "string",
      "minLength": 1
    },
    "human_gate": {
      "$ref": "#/$defs/human_gate"
    },
    "stop_condition": {
      "type": "string",
      "minLength": 1
    },
    "expected_artifact": {
      "type": "string",
      "minLength": 1
    }
  },
  "additionalProperties": false,
  "oneOf": [
    {
      "properties": {
        "status": {
          "enum": [
            "PASS",
            "FAIL",
            "BLOCKED"
          ]
        },
        "human_gate": {
          "type": "object",
          "properties": {
            "approval_state": {
              "const": "NOT_REQUIRED"
            }
          }
        }
      }
    },
    {
      "properties": {
        "status": {
          "const": "HUMAN_APPROVAL_REQUIRED"
        },
        "human_gate": {
          "type": "object",
          "properties": {
            "approval_state": {
              "const": "PENDING"
            }
          }
        }
      }
    },
    {
      "properties": {
        "status": {
          "enum": [
            "PASS",
            "FAIL",
            "BLOCKED"
          ]
        },
        "human_gate": {
          "type": "object",
          "properties": {
            "approval_state": {
              "const": "APPROVED"
            }
          }
        }
      }
    },
    {
      "properties": {
        "status": {
          "const": "BLOCKED"
        },
        "human_gate": {
          "type": "object",
          "properties": {
            "approval_state": {
              "const": "REJECTED"
            }
          }
        }
      }
    }
  ],
  "$defs": {
    "human_gate": {
      "type": "object",
      "required": [
        "required",
        "level",
        "approval_state",
        "approved_scope"
      ],
      "properties": {
        "required": {
          "type": "boolean"
        },
        "level": {
          "type": "integer",
          "minimum": 0,
          "maximum": 3
        },
        "approval_state": {
          "enum": [
            "NOT_REQUIRED",
            "PENDING",
            "APPROVED",
            "REJECTED"
          ]
        },
        "approved_scope": {
          "oneOf": [
            {
              "type": "null"
            },
            {
              "type": "string",
              "minLength": 1,
              "pattern": "\\S"
            }
          ]
        }
      },
      "additionalProperties": false,
      "oneOf": [
        {
          "type": "object",
          "properties": {
            "required": {
              "const": false
            },
            "level": {
              "const": 0
            },
            "approval_state": {
              "const": "NOT_REQUIRED"
            },
            "approved_scope": {
              "type": "null"
            }
          }
        },
        {
          "type": "object",
          "properties": {
            "required": {
              "const": true
            },
            "level": {
              "type": "integer",
              "minimum": 1,
              "maximum": 3
            },
            "approval_state": {
              "const": "PENDING"
            },
            "approved_scope": {
              "type": "null"
            }
          }
        },
        {
          "type": "object",
          "properties": {
            "required": {
              "const": true
            },
            "level": {
              "type": "integer",
              "minimum": 1,
              "maximum": 3
            },
            "approval_state": {
              "const": "APPROVED"
            },
            "approved_scope": {
              "type": "string",
              "minLength": 1,
              "pattern": "\\S"
            }
          }
        },
        {
          "type": "object",
          "properties": {
            "required": {
              "const": true
            },
            "level": {
              "type": "integer",
              "minimum": 1,
              "maximum": 3
            },
            "approval_state": {
              "const": "REJECTED"
            },
            "approved_scope": {
              "type": "null"
            }
          }
        }
      ]
    }
  }
}
