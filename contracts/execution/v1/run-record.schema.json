{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:qa-orchestration-sandbox:execution:v1:run-record",
  "title": "QA orchestration Stage 7 run record",
  "description": "Version 1 contract for a separate Stage 7 execution run record. This contract records run provenance and artifact references only; it does not redefine evidence payload v1, select canonical evidence, assert acceptance, or authorize controlled execution.",
  "$comment": "Out-of-schema semantic invariants deferred to a future approved validator: run_id cohort segment must equal cohort_id; attempt_number must correspond to the R<NN> segment; completed_at must not precede started_at; every scenario cohort must contain exactly two PRIMARY runs and one INDEPENDENT_REPRODUCTION run; referenced files must exist as safe regular non-link files and their SHA-256 values must match; payload, result, evidence, routing trace, and run-record identities must align; execution-input revision and oracle hashes must be identical across an approved cohort; SIM-002 pilot completion must precede any other scenario cohort; canonical manifest selection remains separate from acceptance.",
  "type": "object",
  "required": [
    "schema_version",
    "run_id",
    "cohort_id",
    "scenario_id",
    "execution_role",
    "attempt_number",
    "executor_id",
    "started_at",
    "completed_at",
    "model_id",
    "execution_surface",
    "environment",
    "runtime_versions",
    "provenance",
    "inputs",
    "artifacts"
  ],
  "properties": {
    "schema_version": {
      "const": "1.0.0"
    },
    "run_id": {
      "$ref": "#/$defs/run_id"
    },
    "cohort_id": {
      "enum": [
        "P1",
        "P2",
        "IR"
      ]
    },
    "scenario_id": {
      "$ref": "#/$defs/scenario_id"
    },
    "execution_role": {
      "enum": [
        "PRIMARY",
        "INDEPENDENT_REPRODUCTION"
      ]
    },
    "attempt_number": {
      "type": "integer",
      "minimum": 1,
      "maximum": 99
    },
    "executor_id": {
      "type": "string",
      "pattern": "^synthetic-executor-[a-z0-9][a-z0-9-]{2,63}$"
    },
    "started_at": {
      "$ref": "#/$defs/utc_date_time"
    },
    "completed_at": {
      "$ref": "#/$defs/utc_date_time"
    },
    "model_id": {
      "type": "string",
      "minLength": 1,
      "maxLength": 128,
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]*$"
    },
    "execution_surface": {
      "$ref": "#/$defs/execution_surface"
    },
    "environment": {
      "$ref": "#/$defs/environment"
    },
    "runtime_versions": {
      "$ref": "#/$defs/runtime_versions"
    },
    "provenance": {
      "$ref": "#/$defs/provenance"
    },
    "inputs": {
      "$ref": "#/$defs/inputs"
    },
    "artifacts": {
      "$ref": "#/$defs/artifacts"
    }
  },
  "additionalProperties": false,
  "oneOf": [
    {
      "properties": {
        "scenario_id": {
          "const": "SIM-001"
        },
        "run_id": {
          "type": "string",
          "pattern": "^S7-SIM-001-"
        },
        "inputs": {
          "type": "object",
          "properties": {
            "scenario": {
              "type": "object",
              "properties": {
                "path": {
                  "type": "string",
                  "pattern": "^scenarios/SIM-001-"
                }
              }
            },
            "oracle": {
              "type": "object",
              "properties": {
                "path": {
                  "type": "string",
                  "pattern": "^expected/SIM-001-"
                }
              }
            }
          }
        },
        "artifacts": {
          "type": "object",
          "properties": {
            "payload": {
              "type": "object",
              "properties": {
                "evidence_id": {
                  "type": "string",
                  "pattern": "^SIM-001:"
                },
                "path": {
                  "type": "string",
                  "pattern": "^evidence/runs/SIM-001/S7-SIM-001-"
                }
              }
            },
            "result": {
              "type": "object",
              "properties": {
                "path": {
                  "type": "string",
                  "pattern": "^results/SIM-001-"
                }
              }
            }
          }
        }
      }
    },
    {
      "properties": {
        "scenario_id": {
          "const": "SIM-002"
