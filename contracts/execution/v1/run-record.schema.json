  "$defs": {
    "scenario_id": {
      "enum": [
        "SIM-001",
        "SIM-002",
        "SIM-003",
        "SIM-004",
        "SIM-005",
        "SIM-006"
      ]
    },
    "run_id": {
      "type": "string",
      "pattern": "^S7-SIM-00[1-6]-(P1|P2|IR)-R[0-9]{2}$"
    },
    "sha1": {
      "type": "string",
      "pattern": "^[a-f0-9]{40}$"
    },
    "sha256": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$"
    },
    "utc_date_time": {
      "type": "string",
      "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}Z$"
    },
    "safe_repository_path": {
      "type": "string",
      "pattern": "^(?!/)(?![A-Za-z]:)(?!//)(?!.*//)(?!.*\\\\)(?!.*(^|/)\\.(/|$))(?!.*(^|/)\\.\\.(/|$))(?!.*\\/$)[A-Za-z0-9._/-]+$"
    },
    "scenario_path": {
      "allOf": [
        {
          "$ref": "#/$defs/safe_repository_path"
        },
        {
          "type": "string",
          "pattern": "^scenarios/SIM-00[1-6]-[A-Za-z0-9._/-]+\\.md$"
        }
      ]
    },
    "fixture_path": {
      "allOf": [
        {
          "$ref": "#/$defs/safe_repository_path"
        },
        {
          "type": "string",
          "pattern": "^fixtures/[A-Za-z0-9._/-]+$"
        }
      ]
    },
    "oracle_path": {
      "allOf": [
        {
          "$ref": "#/$defs/safe_repository_path"
        },
        {
          "type": "string",
          "pattern": "^expected/SIM-00[1-6]-[A-Za-z0-9._/-]+\\.md$"
        }
      ]
    },
    "payload_path": {
      "allOf": [
        {
          "$ref": "#/$defs/safe_repository_path"
        },
        {
          "type": "string",
          "pattern": "^evidence/runs/SIM-00[1-6]/S7-SIM-00[1-6]-(P1|P2|IR)-R[0-9]{2}\\.payload\\.json$"
        }
      ]
    },
    "result_path": {
      "allOf": [
        {
          "$ref": "#/$defs/safe_repository_path"
        },
        {
          "type": "string",
          "pattern": "^results/SIM-00[1-6]-[A-Za-z0-9._/-]+\\.md$"
        }
      ]
    },
    "execution_surface": {
      "type": "object",
      "required": [
        "name",
        "version"
      ],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1,
          "maxLength": 80,
          "pattern": "^[A-Za-z0-9][A-Za-z0-9 ._:-]*$"
        },
        "version": {
          "type": "string",
          "minLength": 1,
          "maxLength": 80,
          "pattern": "^[A-Za-z0-9][A-Za-z0-9 ._:-]*$"
        }
      },
      "additionalProperties": false
    },
    "environment": {
      "type": "object",
      "required": [
        "os",
        "architecture"
      ],
      "properties": {
        "os": {
          "type": "object",
          "required": [
            "name",
            "version"
          ],
          "properties": {
            "name": {
              "type": "string",
              "minLength": 1,
              "maxLength": 80,
              "pattern": "^[A-Za-z0-9][A-Za-z0-9 ._:-]*$"
            },
            "version": {
              "type": "string",
              "minLength": 1,
              "maxLength": 80,
              "pattern": "^[A-Za-z0-9][A-Za-z0-9 ._:-]*$"
            }
          },
          "additionalProperties": false
        },
        "architecture": {
          "enum": [
            "x64",
            "arm64"
          ]
        }
      },
      "additionalProperties": false
    },
    "runtime_versions": {
      "type": "object",
      "required": [
        "python",
        "git",
        "node",
        "npm",
        "npx",
        "ajv_cli",
        "sandbox_validator"
      ],
      "properties": {
        "python": {
          "type": "string",
          "minLength": 1,
          "maxLength": 80
        },
        "git": {
          "type": "string",
          "minLength": 1,
          "maxLength": 80
        },
        "node": {
          "type": "string",
          "minLength": 1,
          "maxLength": 80
        },
        "npm": {
          "type": "string",
          "minLength": 1,
          "maxLength": 80
        },
        "npx": {
          "type": "string",
          "minLength": 1,
          "maxLength": 80
        },
        "ajv_cli": {
          "type": "string",
          "minLength": 1,
          "maxLength": 80
        },
        "sandbox_validator": {
          "type": "string",
          "minLength": 1,
          "maxLength": 80
        }
      },
      "additionalProperties": false
    },
    "provenance": {
      "type": "object",
      "required": [
        "consumer_execution_input",
        "hub_pin",
        "schema_versions"
      ],
      "properties": {
        "consumer_execution_input": {
          "$ref": "#/$defs/sha1"
        },
        "hub_pin": {
          "$ref": "#/$defs/sha1"
        },
        "schema_versions": {
          "type": "object",
          "required": [
            "payload",
            "routing_trace",
            "run_record"
          ],
          "properties": {
            "payload": {
              "const": "1.0.0"
            },
            "routing_trace": {
              "const": "1.0.0"
            },
            "run_record": {
              "const": "1.0.0"
            }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    },
    "hashed_file": {
      "type": "object",
      "required": [
        "path",
        "sha256"
      ],
      "properties": {
        "path": {
          "$ref": "#/$defs/safe_repository_path"
        },
        "sha256": {
          "$ref": "#/$defs/sha256"
        }
      },
      "additionalProperties": false
    },
    "scenario_file": {
      "type": "object",
      "required": [
        "path",
        "sha256"
      ],
      "properties": {
        "path": {
          "$ref": "#/$defs/scenario_path"
        },
        "sha256": {
          "$ref": "#/$defs/sha256"
        }
      },
      "additionalProperties": false
    },
    "fixture_file": {
      "type": "object",
      "required": [
        "path",
        "sha256"
      ],
      "properties": {
        "path": {
          "$ref": "#/$defs/fixture_path"
        },
        "sha256": {
          "$ref": "#/$defs/sha256"
        }
      },
      "additionalProperties": false
    },
    "oracle_file": {
      "type": "object",
      "required": [
        "path",
        "sha256"
      ],
      "properties": {
        "path": {
          "$ref": "#/$defs/oracle_path"
        },
        "sha256": {
          "$ref": "#/$defs/sha256"
        }
      },
      "additionalProperties": false
    },
    "inputs": {
      "type": "object",
      "required": [
        "scenario",
        "fixtures",
        "oracle"
      ],
      "properties": {
        "scenario": {
          "$ref": "#/$defs/scenario_file"
        },
        "fixtures": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/fixture_file"
          }
        },
        "oracle": {
          "$ref": "#/$defs/oracle_file"
        }
      },
      "additionalProperties": false
    },
    "payload_artifact": {
      "type": "object",
      "required": [
        "path",
        "sha256",
        "evidence_id"
      ],
      "properties": {
        "path": {
          "$ref": "#/$defs/payload_path"
        },
        "sha256": {
          "$ref": "#/$defs/sha256"
        },
        "evidence_id": {
          "type": "string",
          "pattern": "^SIM-00[1-6]:[a-z0-9][a-z0-9._-]*:v1$"
        }
      },
      "additionalProperties": false
    },
    "result_artifact": {
      "type": "object",
      "required": [
        "path",
        "sha256"
      ],
      "properties": {
        "path": {
          "$ref": "#/$defs/result_path"
        },
        "sha256": {
          "$ref": "#/$defs/sha256"
        }
      },
      "additionalProperties": false
    },
    "artifacts": {
      "type": "object",
      "required": [
        "payload",
        "result"
      ],
      "properties": {
        "payload": {
          "$ref": "#/$defs/payload_artifact"
        },
        "result": {
          "$ref": "#/$defs/result_artifact"
        }
      },
      "additionalProperties": false
    }
  }
}
