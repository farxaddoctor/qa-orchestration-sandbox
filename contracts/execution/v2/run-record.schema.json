{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:qa-orchestration-sandbox:execution:v2:run-record",
  "title": "QA orchestration Stage 7 run record v2",
  "description": "Version 2 contract for Stage 7 controlled execution run records. It separates frozen execution input from actual execution repository revision, records post-run C1-C10 evaluation and validator result, and models unavailable execution-surface versions without permitting false reproducibility claims.",
  "$comment": "Out-of-schema semantic invariants enforced by the sandbox validator include run_id/cohort/attempt alignment, timestamp ordering, referenced file hash checks, payload/result/provenance alignment, C1-C10 score totals, oracle evaluation alignment, revision-delta review requirements, and rejecting reproducibility claims when exact execution-surface version is unavailable.",
  "type": "object",
  "required": [
    "schema_version",
    "run_id",
    "cohort_id",
    "scenario_id",
    "execution_role",
    "attempt_number",
    "executor_id",
    "started_at",
    "completed_at",
    "model_id",
    "execution_surface",
    "environment",
    "runtime_versions",
    "provenance",
    "inputs",
    "artifacts",
    "evaluation"
  ],
  "properties": {
    "schema_version": {
      "const": "2.0.0"
    },
    "run_id": {
      "$ref": "#/$defs/run_id"
    },
    "cohort_id": {
      "enum": [
        "P1",
        "P2",
        "IR"
      ]
    },
    "scenario_id": {
      "$ref": "#/$defs/scenario_id"
    },
    "execution_role": {
      "enum": [
        "PRIMARY",
        "INDEPENDENT_REPRODUCTION"
      ]
    },
    "attempt_number": {
      "type": "integer",
      "minimum": 1,
      "maximum": 99
    },
    "executor_id": {
      "type": "string",
      "pattern": "^synthetic-executor-[a-z0-9][a-z0-9-]{2,63}$"
    },
    "started_at": {
      "$ref": "#/$defs/utc_date_time"
    },
    "completed_at": {
      "$ref": "#/$defs/utc_date_time"
    },
    "model_id": {
      "type": "string",
      "minLength": 1,
      "maxLength": 128,
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]*$"
    },
    "execution_surface": {
      "$ref": "#/$defs/execution_surface"
    },
    "environment": {
      "$ref": "#/$defs/environment"
    },
    "runtime_versions": {
      "$ref": "#/$defs/runtime_versions"
    },
    "provenance": {
      "$ref": "#/$defs/provenance"
    },
    "inputs": {
      "$ref": "#/$defs/inputs"
    },
    "artifacts": {
      "$ref": "#/$defs/artifacts"
    },
    "evaluation": {
      "$ref": "#/$defs/evaluation"
    }
  },
  "additionalProperties": false,
  "$defs": {
    "scenario_id": {
      "type": "string",
      "enum": [
        "SIM-001",
        "SIM-002",
        "SIM-003",
        "SIM-004",
        "SIM-005",
        "SIM-006"
      ]
    },
    "run_id": {
      "type": "string",
      "pattern": "^S7-SIM-00[1-6]-(P1|P2|IR)-R[0-9]{2}$"
    },
    "hex40": {
      "type": "string",
      "pattern": "^[a-f0-9]{40}$"
    },
    "sha256": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$"
    },
    "utc_date_time": {
      "type": "string",
      "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}Z$"
    },
    "safe_path": {
      "type": "string",
      "minLength": 1,
      "maxLength": 240,
      "not": {
        "anyOf": [
          {
            "pattern": "^[A-Za-z]:"
          },
          {
            "pattern": "^/"
          },
          {
            "pattern": "^\\\\"
          },
          {
            "pattern": "\\\\"
          },
          {
            "pattern": "(^|/)\\.\\.?(/|$)"
          },
          {
            "pattern": "//"
          }
        ]
      }
    },
    "hashed_file": {
      "type": "object",
      "required": [
        "path",
        "sha256"
      ],
      "properties": {
        "path": {
          "$ref": "#/$defs/safe_path"
        },
        "sha256": {
          "$ref": "#/$defs/sha256"
        }
      },
      "additionalProperties": false
    },
    "execution_surface": {
      "type": "object",
      "required": [
        "name",
        "version"
      ],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1,
          "maxLength": 128
        },
        "version": {
          "oneOf": [
            {
              "type": "object",
              "required": [
                "availability",
                "value"
              ],
              "properties": {
                "availability": {
                  "const": "EXACT"
                },
                "value": {
                  "type": "string",
                  "minLength": 1,
                  "maxLength": 128
                }
              },
              "additionalProperties": false
            },
            {
              "type": "object",
              "required": [
                "availability",
                "reason"
              ],
              "properties": {
                "availability": {
                  "const": "UNAVAILABLE"
                },
                "reason": {
                  "type": "string",
                  "minLength": 1,
                  "maxLength": 256
                }
              },
              "additionalProperties": false
            }
          ]
        }
      },
      "additionalProperties": false
    },
    "environment": {
      "type": "object",
      "required": [
        "os",
        "architecture"
      ],
      "properties": {
        "os": {
          "type": "object",
          "required": [
            "name",
            "version"
          ],
          "properties": {
            "name": {
              "type": "string",
              "minLength": 1,
              "maxLength": 80
            },
            "version": {
              "type": "string",
              "minLength": 1,
              "maxLength": 80
            }
          },
          "additionalProperties": false
        },
        "architecture": {
          "enum": [
            "x64",
            "arm64"
          ]
        }
      },
      "additionalProperties": false
    },
    "runtime_versions": {
      "type": "object",
      "required": [
        "python",
        "git",
        "node",
        "npm",
        "npx",
        "ajv_cli",
        "sandbox_validator"
      ],
      "properties": {
        "python": {
          "type": "string",
          "minLength": 1,
          "maxLength": 80
        },
        "git": {
          "type": "string",
          "minLength": 1,
          "maxLength": 80
        },
        "node": {
          "type": "string",
          "minLength": 1,
          "maxLength": 80
        },
        "npm": {
          "type": "string",
          "minLength": 1,
          "maxLength": 80
        },
        "npx": {
          "type": "string",
          "minLength": 1,
          "maxLength": 80
        },
        "ajv_cli": {
          "type": "string",
          "minLength": 1,
          "maxLength": 80
        },
        "sandbox_validator": {
          "type": "string",
          "minLength": 1,
          "maxLength": 80
        }
      },
      "additionalProperties": false
    },
    "provenance": {
      "type": "object",
      "required": [
        "execution_input_revision",
        "execution_repository_revision",
        "hub_pin",
        "revision_delta",
        "schema_versions"
      ],
      "properties": {
        "execution_input_revision": {
          "$ref": "#/$defs/hex40"
        },
        "execution_repository_revision": {
          "$ref": "#/$defs/hex40"
        },
        "hub_pin": {
          "$ref": "#/$defs/hex40"
        },
        "revision_delta": {
          "type": "object",
          "required": [
            "allowed",
            "execution_affecting_change_present",
            "reason",
            "review_reference"
          ],
          "properties": {
            "allowed": {
              "type": "boolean"
            },
            "execution_affecting_change_present": {
              "type": "boolean"
            },
            "reason": {
              "type": "string",
              "minLength": 1,
              "maxLength": 512
            },
            "review_reference": {
              "type": "string",
              "minLength": 1,
              "maxLength": 240
            }
          },
          "additionalProperties": false
        },
        "schema_versions": {
          "type": "object",
          "required": [
            "payload",
            "routing_trace",
            "run_record"
          ],
          "properties": {
            "payload": {
              "const": "1.0.0"
            },
            "routing_trace": {
              "const": "1.0.0"
            },
            "run_record": {
              "const": "2.0.0"
            }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    },
    "inputs": {
      "type": "object",
      "required": [
        "scenario",
        "fixtures",
        "oracle"
      ],
      "properties": {
        "scenario": {
          "$ref": "#/$defs/hashed_file"
        },
        "fixtures": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/hashed_file"
          }
        },
        "oracle": {
          "$ref": "#/$defs/hashed_file"
        }
      },
      "additionalProperties": false
    },
    "artifacts": {
      "type": "object",
      "required": [
        "payload",
        "result"
      ],
      "properties": {
        "payload": {
          "type": "object",
          "required": [
            "path",
            "sha256",
            "evidence_id"
          ],
          "properties": {
            "path": {
              "$ref": "#/$defs/safe_path"
            },
            "sha256": {
              "$ref": "#/$defs/sha256"
            },
            "evidence_id": {
              "type": "string",
              "pattern": "^SIM-00[1-6]:[a-z0-9][a-z0-9._-]*:v1$"
            }
          },
          "additionalProperties": false
        },
        "result": {
          "$ref": "#/$defs/hashed_file"
        }
      },
      "additionalProperties": false
    },
    "criterion": {
      "type": "object",
      "required": [
        "id",
        "name",
        "passed",
        "score",
        "evidence"
      ],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^C([1-9]|10)$"
        },
        "name": {
          "type": "string",
          "minLength": 1,
          "maxLength": 80
        },
        "passed": {
          "type": "boolean"
        },
        "score": {
          "type": "integer",
          "minimum": 0,
          "maximum": 1
        },
        "evidence": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1,
            "maxLength": 240
          }
        }
      },
      "additionalProperties": false
    },
    "evaluation": {
      "type": "object",
      "required": [
        "criteria",
        "total_score",
        "result",
        "oracle",
        "evaluator_id",
        "method",
        "validator_result",
        "run_acceptance",
        "reproducibility"
      ],
      "properties": {
        "criteria": {
          "type": "object",
          "required": [
            "C1",
            "C2",
            "C3",
            "C4",
            "C5",
            "C6",
            "C7",
            "C8",
            "C9",
            "C10"
          ],
          "properties": {
            "C1": {
              "$ref": "#/$defs/criterion"
            },
            "C2": {
              "$ref": "#/$defs/criterion"
            },
            "C3": {
              "$ref": "#/$defs/criterion"
            },
            "C4": {
              "$ref": "#/$defs/criterion"
            },
            "C5": {
              "$ref": "#/$defs/criterion"
            },
            "C6": {
              "$ref": "#/$defs/criterion"
            },
            "C7": {
              "$ref": "#/$defs/criterion"
            },
            "C8": {
              "$ref": "#/$defs/criterion"
            },
            "C9": {
              "$ref": "#/$defs/criterion"
            },
            "C10": {
              "$ref": "#/$defs/criterion"
            }
          },
          "additionalProperties": false
        },
        "total_score": {
          "type": "integer",
          "minimum": 0,
          "maximum": 10
        },
        "result": {
          "enum": [
            "PASS",
            "FAIL"
          ]
        },
        "oracle": {
          "$ref": "#/$defs/hashed_file"
        },
        "evaluator_id": {
          "type": "string",
          "pattern": "^synthetic-evaluator-[a-z0-9][a-z0-9-]{2,63}$"
        },
        "method": {
          "const": "C1-C10_BINARY"
        },
        "validator_result": {
          "type": "object",
          "required": [
            "validator_id",
            "command",
            "exit_code",
            "result",
            "validated_at"
          ],
          "properties": {
            "validator_id": {
              "type": "string",
              "minLength": 1,
              "maxLength": 128
            },
            "command": {
              "type": "string",
              "minLength": 1,
              "maxLength": 240
            },
            "exit_code": {
              "type": "integer",
              "minimum": 0,
              "maximum": 255
            },
            "result": {
              "enum": [
                "PASS",
                "FAIL"
              ]
            },
            "validated_at": {
              "$ref": "#/$defs/utc_date_time"
            }
          },
          "additionalProperties": false
        },
        "run_acceptance": {
          "enum": [
            "ACCEPTED",
            "NOT_ACCEPTED"
          ]
        },
        "reproducibility": {
          "type": "object",
          "required": [
            "claimed",
            "result",
            "reason"
          ],
          "properties": {
            "claimed": {
              "type": "boolean"
            },
            "result": {
              "enum": [
                "PASS",
                "FAIL",
                "NOT_CLAIMED"
              ]
            },
            "reason": {
              "type": "string",
              "minLength": 1,
              "maxLength": 512
            }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    }
  }
}
